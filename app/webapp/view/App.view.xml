<mvc:View
  controllerName="tictactoe.app.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  xmlns="sap.m"
  displayBlock="true">

  <App>
    <Page title="Tic Tac Toe" class="sapUiContentPadding">
      <content>
        <HBox class="page-content">

          <VBox class="game-container">
            <HBox class="session-config">
              <SegmentedButton id="modeSelect" selectedKey="{session>/mode}"
                               enabled="{= ${game>/gameState} === 'NOT_STARTED' }">
                <items>
                  <SegmentedButtonItem key="HvH" text="vs Human"/>
                  <SegmentedButtonItem key="HvB" text="vs Bot"/>
                </items>
              </SegmentedButton>
              <Select id="bestOfSelect" selectedKey="{session>/bestOf}"
                      enabled="{= ${game>/gameState} === 'NOT_STARTED' }">
                <core:Item key="3" text="Best of 3"/>
                <core:Item key="5" text="Best of 5"/>
                <core:Item key="7" text="Best of 7"/>
              </Select>
              <Button text="{= ${game>/gameState} === 'NOT_STARTED' ? 'Start Session' : 'Reset Session' }"
                      press=".onSessionButton" type="Emphasized"/>
            </HBox>

            <VBox class="session-info-wrapper">
              <HBox class="score-display" visible="{= ${game>/gameState} !== 'NOT_STARTED' }">
                <ObjectStatus title="X" text="{session>/xWins}" state="Information"/>
                <Text text=" - " class="score-separator"/>
                <ObjectStatus title="O" text="{session>/oWins}" state="Information"/>
                <Text text="  |  Draws: {session>/draws}" class="draws-text"/>
              </HBox>
            </VBox>

            <VBox>
              <core:Fragment fragmentName="tictactoe.app.view.GameBoard" type="XML"/>
              <Text text="You are X  ·  Bot is O"
                    visible="{= ${session>/mode} === 'HvB' &amp;&amp; ${game>/gameState} !== 'NOT_STARTED' }"
                    class="bot-hint"/>
            </VBox>

            <Button text="Next Match" press=".onNextMatch" type="Emphasized"
                    visible="{= ${game>/gameState} === 'MATCH_OVER' }"
                    class="session-action"/>

            <VBox visible="{= ${game>/gameState} === 'SESSION_OVER' }" class="session-complete">
              <MessageStrip
                text="{= ${session>/mode} === 'HvB'
                  ? (${session>/sessionWinner} === 'X' ? 'You win the session!' : 'Bot wins the session!')
                  : 'Player ' + ${session>/sessionWinner} + ' wins the session!'}"
                type="Success"
                showIcon="true"
                class="session-winner"/>
              <Button text="Start New Session" press=".onEndSession" type="Emphasized" class="session-action"/>
            </VBox>
          </VBox>

          <VBox class="history-container">
            <Title text="Match History"/>
            <List noDataText="No completed games yet"
                  items="{game>/history}">
              <StandardListItem
                title="{= ${game>winner} === 'draw' ? 'Draw' : 'Player ' + ${game>winner} + ' won'}"
                description="{game>completedAtFormatted}" />
            </List>
          </VBox>

        </HBox>
      </content>
    </Page>
  </App>
</mvc:View>
